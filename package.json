{
  "name": "performance-hud",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch . --ext js,html,css --exec electron .",
    "build": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.performance.hud",
    "linux": {
      "target": "AppImage",
      "category": "System"
    }
  },
  "devDependencies": {
    "electron": "*",
    "electron-builder": "^26.8.1",
    "nodemon": "beta 0.1"
  },
  "dependencies": {
    "systeminformation": "*"
  }
}
